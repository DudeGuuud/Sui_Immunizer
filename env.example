# =============================================================================
# Sui-Immunizer — Environment Configuration
# Copy to .env (backend agent) and web/.env.local (frontend).
# =============================================================================

# ─── Sui Blockchain ───────────────────────────────────────────────────────────
# Used by: agent daemon (backend)
SUI_NETWORK=testnet
SUI_MNEMONIC="word1 word2 ... word12"

# Obtained after: cd move && sui client publish --gas-budget 100000000
IMMUNIZER_PACKAGE_ID=0x_REPLACE_AFTER_PUBLISH
IMMUNIZER_REGISTRY_ID=0x_REPLACE_AFTER_PUBLISH

# ─── Walrus ───────────────────────────────────────────────────────────────────
# Used by: agent daemon (backend)
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# ─── Seal Key Servers (Mysten Labs Open Mode — testnet) ───────────────────────
# 2-of-2 threshold: both must cooperate to decrypt
# Object IDs from https://seal-docs.wal.app
# Used by: agent daemon (backend)
SEAL_KEY_SERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
SEAL_KEY_SERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8

# ─── OpenClaw (agent daemon) ──────────────────────────────────────────────────
# Used by: agent daemon (backend)
OPENCLAW_PROVIDER=anthropic
OPENCLAW_MODEL=claude-sonnet-4-20250514
OPENCLAW_WORKSPACE=~/.openclaw/workspace/immunizer
# Delivery channel session key — format: main:<channel>:<id>
OPENCLAW_NOTIFY_SESSION_KEY=main:telegram:immunizer

# =============================================================================
# Frontend (web/) — copy below to web/.env.local
# NEXT_PUBLIC_ prefix is required for browser-accessible variables.
# =============================================================================

# ─── Sui Network ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=testnet

# ─── Contract Addresses ───────────────────────────────────────────────────────
NEXT_PUBLIC_PACKAGE_ID=0x_REPLACE_AFTER_PUBLISH
NEXT_PUBLIC_REGISTRY_ID=0x_REPLACE_AFTER_PUBLISH

# ─── Walrus ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_STORAGE_EPOCHS=5

# ─── Seal Key Servers ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SEAL_KEY_SERVER_1=0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
NEXT_PUBLIC_SEAL_KEY_SERVER_2=0xf5d14a81a982144ae441cd7d64b09027f116a468bd36e7eca494f750591623c8
